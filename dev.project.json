{
    "name": "luau-futures",
    "tree": {
        "$className": "DataModel",
        "ReplicatedStorage": {
            "DevPackages": {
                "$path": {
                    "optional": "DevPackages"
                }
            },
            "Packages": {
                "$className": "Folder",
                "Project": {
                    "$path": "dist/src"
                }
            }
        },
        "ServerScriptService": {
            "run-tests": {
                "$path": "dist/run-tests.server.luau"
            }
        }
    }
}
